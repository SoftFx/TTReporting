FROM mcr.microsoft.com/dotnet/sdk:8.0

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

RUN set -eux; \
  apt-get update; \
  apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    ca-certificates \
    curl \
    git; \
  rm -rf /var/lib/apt/lists/*

RUN set -eux; \
  python3 -m pip install --no-cache-dir --break-system-packages \
    pandas \
    requests \
    PyYAML \
    urllib3

# 1) Application code
COPY sourcePython/swap-updater/ /app

# 2) Shared Python code
RUN mkdir -p /common
COPY sourcePython/common/ /common/

RUN chmod -R a+rX /common

# 3) Runtime folders
RUN set -eux; \
  mkdir -p /app/dataDocker/today; \
  mkdir -p /app/dataDocker/storage; \
  mkdir -p /app/dataDocker/log

# 4) Sanity checks for non-private files only
RUN set -eux; \
  test -f /app/main.py; \
  test -f /common/hsm_report.py; \
  test -f /app/diff.py; \
  test -f /app/swap_markup.py; \
  test -f /app/TtsSwapsFetcher/TtsSwapsFetcher.csproj; \
  test -f /app/TtsSwapsUploader/TtsSwapsUploader.csproj; \
  test -d /app/libs; \
  test -d /app/libs/tts

ENV PYTHONPATH=/common:/app
ENV SWAP_UPDATER_ROOT=/app

WORKDIR /app

ENTRYPOINT ["python3", "main.py"]