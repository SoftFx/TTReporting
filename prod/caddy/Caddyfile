{
    auto_https off
}

# Users are defined in users.caddyfile (gitignored)
import users.caddyfile

:80 {
    redir https://{host}{uri} permanent
}

:443 {
    tls /srv/home/server.crt /srv/home/server.key

    root * /srv/home

    # ── Home page — all authenticated users ──────
    handle / {
        basic_auth {
            import all-users
        }
        file_server {
            index index.html
        }
    }

    # ── Download root CA certificate (public) ────
    handle /root-ca.crt {
        file_server
    }

    # ── products.yaml (same auth as home) ────────
    handle /products.yaml {
        basic_auth {
            import all-users
        }
        file_server
    }

    # ── Aggregator Data ─────────────────────────
    handle /aggr-data/* {
        basic_auth {
            import admin_creads
            import aggr-data-users
        }
        uri strip_prefix /aggr-data
        reverse_proxy aggr-data-app:3838
    }

    # ── Catch-all: deny everything else ──────────
    handle {
        respond 403
    }

    log {
        output stdout
        format json
    }
}
