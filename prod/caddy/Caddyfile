{
    auto_https off
}

# Users are defined in users.caddyfile (gitignored)
import users.caddyfile

:80 {
    redir https://{host}{uri} permanent
}

:443 {
    tls /srv/certs/server.crt /srv/certs/server.key

    # ── Security headers ──────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # ── Rate limiting (requires caddy-ratelimit plugin) ──
    # Uncomment after adding the plugin to the Caddy image:
    # rate_limit {
    #     zone auth_zone {
    #         key {remote_host}
    #         events 20
    #         window 60s
    #     }
    # }

    root * /srv/home

    # ── Home page — all authenticated users ──────
    handle / {
        basic_auth {
            import all-users
        }
        file_server {
            index index.html
        }
    }

    # ── Download root CA certificate (public) ────
    handle /root-ca.crt {
        file_server
    }

    # ── products.yaml (same auth as home) ────────
    handle /products.yaml {
        basic_auth {
            import all-users
        }
        file_server
    }

    # ── Aggregator Data ─────────────────────────
    handle /aggr-data/* {
        basic_auth {
            import admin_creads
            import aggr-data-users
        }
        uri strip_prefix /aggr-data
        reverse_proxy aggr-data-app:3838
    }

    # ── Catch-all: deny everything else ──────────
    handle {
        respond 403
    }

    log {
        output stdout
        format json
    }
}
