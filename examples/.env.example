# Copy to .env and fill in real values. .env is gitignored.
# This file sits next to docker-compose.yml — docker-compose reads it automatically
# and injects the variables into containers via the environment: block.
# This mirrors what lives on the server next to its docker-compose.yml.

# Quote values containing special chars like #, $, spaces, e.g. MT5_PASSWORD="pa$$#word"
MT4_PASSWORD=
MT5_PASSWORD=
PG_PASSWORD=
